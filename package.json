{
  "name": "locus",
  "author": "sloth8497",
  "version": "1.0.0",
  "license": "MIT",
  "keywords": [
    "pebble-app"
  ],
  "private": true,
  "dependencies": {
    "@rebble/clay": "^1.0.10",
    "pako": "^1.0.11",
    "upng-js": "^2.1.0"
  },
  "pebble": {
    "displayName": "Locus",
    "uuid": "307fcb13-d8ff-49a9-af00-48578bf970e8",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "aplite",
      "basalt",
      "chalk",
      "diorite",
      "emery",
      "flint",
      "gabbro"
    ],
    "watchapp": {
      "watchface": true
    },
    "messageKeys": [
      "API_KEY",
      "LOCATION_MODE",
      "FIXED_LAT",
      "FIXED_LON",
      "UPDATE_DISTANCE",
      "UPDATE_INTERVAL",
      "ZOOM",
      "SHOW_LABELS",
      "MAP_STYLE",
      "MAP_COLOR_BG",
      "MAP_COLOR_1",
      "MAP_COLOR_2",
      "MAP_COLOR_3",
      "MAP_TONE_BG",
      "MAP_TONE_1",
      "MAP_TONE_2",
      "MAP_TONE_3",
      "TIME_COLOR",
      "DATE_COLOR",
      "SHOW_DATE",
      "SHOW_CENTER_DOT",
      "SHOW_STATUS",
      "TIME_FONT",
      "DATE_FONT",
      "REQUEST_UPDATE",
      "STATUS",
      "IMG_SIZE",
      "IMG_OFFSET",
      "IMG_DATA",
      "IMG_COMPLETE"
    ],
    "resources": {
      "media": [
        {
          "type": "png",
          "name": "IMAGE_MENU_ICON",
          "file": "images/icon-25.png",
          "menuIcon": true
        },

        // BitcountSingle-Regular — time (digits + colon only)
        { "type": "font", "name": "FONT_BITCOUNT_REG_42", "file": "fonts/BitcountSingle-Regular.ttf", "characterRegex": "[0-9:]" },
        { "type": "font", "name": "FONT_BITCOUNT_REG_60", "file": "fonts/BitcountSingle-Regular.ttf", "characterRegex": "[0-9:]" },

        // BitcountSingle-Bold — time (digits + colon only)
        { "type": "font", "name": "FONT_BITCOUNT_BOLD_42", "file": "fonts/BitcountSingle-Bold.ttf", "characterRegex": "[0-9:]" },
        { "type": "font", "name": "FONT_BITCOUNT_BOLD_60", "file": "fonts/BitcountSingle-Bold.ttf", "characterRegex": "[0-9:]" },

        // Jersey25-Regular — time (digits + colon only)
        { "type": "font", "name": "FONT_JERSEY_42", "file": "fonts/Jersey25-Regular.ttf", "characterRegex": "[0-9:]" },
        { "type": "font", "name": "FONT_JERSEY_60", "file": "fonts/Jersey25-Regular.ttf", "characterRegex": "[0-9:]" },

        // BitcountSingle-Regular — date (abbreviated day + date + month)
        { "type": "font", "name": "FONT_BITCOUNT_REG_21", "file": "fonts/BitcountSingle-Regular.ttf", "characterRegex": "[A-Za-z0-9 ]" },
        { "type": "font", "name": "FONT_BITCOUNT_REG_28", "file": "fonts/BitcountSingle-Regular.ttf", "characterRegex": "[A-Za-z0-9 ]" },

        // Jersey25-Regular — date
        { "type": "font", "name": "FONT_JERSEY_21", "file": "fonts/Jersey25-Regular.ttf", "characterRegex": "[A-Za-z0-9 ]" },
        { "type": "font", "name": "FONT_JERSEY_28", "file": "fonts/Jersey25-Regular.ttf", "characterRegex": "[A-Za-z0-9 ]" }
      ]
    },
    "capabilities": [
      "location",
      "configurable"
    ]
  }
}
